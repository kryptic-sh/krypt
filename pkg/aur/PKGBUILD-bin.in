# Maintainer: mxaddict <mxaddict at kryptic dot sh>
#
# Auto-generated. Source: https://github.com/mxaddict/files
# Edits made directly to the AUR repo will be overwritten on the next
# release. To change this PKGBUILD, edit `pkg/aur/PKGBUILD-bin.in` in
# the upstream repo and let `.github/workflows/release.yml` republish.
pkgname=files-bin
_pkgname=files
pkgver={VERSION}
pkgrel=1
pkgdesc="Cross-platform dotfiles manager. Rust binary. Config-driven. (binary release)"
arch=('x86_64' 'aarch64')
url="https://github.com/mxaddict/files"
license=('MIT')
provides=("$_pkgname=$pkgver")
conflicts=("$_pkgname")
depends=('glibc')

source_x86_64=("files-v${pkgver}-x86_64-unknown-linux-gnu.tar.gz::https://github.com/mxaddict/files/releases/download/v${pkgver}/files-v${pkgver}-x86_64-unknown-linux-gnu.tar.gz")
source_aarch64=("files-v${pkgver}-aarch64-unknown-linux-gnu.tar.gz::https://github.com/mxaddict/files/releases/download/v${pkgver}/files-v${pkgver}-aarch64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('{SHA256_X86_64}')
sha256sums_aarch64=('{SHA256_AARCH64}')

package() {
    install -Dm755 "$srcdir/files" "$pkgdir/usr/bin/files"
    install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$srcdir/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
